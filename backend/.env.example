# ─────────────────────────────────────────────────────
# SPI Backend — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file, rename it to ".env", and fill in your values.
# NEVER share or commit the .env file publicly.

# Your Gmail address (the one that sends/receives notifications)
OWNER_EMAIL=shriparamhansinternational@gmail.com

# Gmail App Password (16 characters, no spaces)
# How to get it:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (if not already)
#   3. Search for "App Passwords" in the search bar
#   4. Select App: Mail → Device: Other → type "SPI Website"
#   5. Click Generate → copy the 16-character password below
GMAIL_APP_PASSWORD=your_16_character_app_password_here

# Server port (optional, default is 5000)
PORT=5000

# Your production frontend URL (set this after deploying to Netlify)
# Example: https://your-site.netlify.app  OR  https://yourdomain.com
FRONTEND_URL=https://your-site.netlify.app
